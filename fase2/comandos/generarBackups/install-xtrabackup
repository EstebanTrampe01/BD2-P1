# Comando para instalar imagen de XtraBackup

cd "/home/dant/Escritorio/Repository/Usac/BD2/BD2-P1/fase2"
mkdir -p logs_tiempo evidencias

START="$(date '+%Y-%m-%d %H:%M:%S')"
/usr/bin/time -f "%e" -o logs_tiempo/install_xtrabackup.sec \
docker pull percona/percona-xtrabackup:8.0
END="$(date '+%Y-%m-%d %H:%M:%S')"

{
  echo "INSTALACION XTRABACKUP"
  echo "inicio=$START"
  echo "fin=$END"
  echo "duracion_seg=$(cat logs_tiempo/install_xtrabackup.sec)"
} > evidencias/install_xtrabackup_resumen.txt
